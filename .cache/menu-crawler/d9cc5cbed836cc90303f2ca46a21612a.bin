</div></div></div></div></div></div></div></section><section class="l-section wpb_row height_small width_full"><div class="l-section-h i-cf"><div class="g-cols vc_row via_flex valign_top type_default stacking_default" style="--additional-gap:1vw;"><div class="vc_col-sm-12 wpb_column vc_column_container"><div class="vc_column-inner"><div class="wpb_wrapper"><div class="wpb_text_column us_custom_8e09cc6b"><div class="wpb_wrapper"><p style="text-align: center;"><strong>MONTAG, 23.02.</strong><br />
